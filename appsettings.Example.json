{
  "_comment": "Template only. Copy to appsettings.Development.json for local dev (gitignored), or set values via environment variables / dotnet user-secrets. Never commit real secrets.",

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=pos_dev;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Prefer;Trust Server Certificate=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "DetailedErrors": true,
  "Jwt": {
    "SecretKey": "REPLACE_WITH_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS_LONG",
    "Issuer": "POSSystemAPI",
    "Audience": "POSSystemClients",
    "AccessTokenExpirationMinutes": "60",
    "RefreshTokenExpirationDays": "7"
  },

  "_serilog_comment": "Optional. Leave Serilog:Seq:ServerUrl empty to disable Seq shipping; the app still logs to console + rolling file. See docs/observability.md.",
  "Serilog": {
    "Seq": {
      "ServerUrl": "",
      "ApiKey": ""
    }
  }
}
